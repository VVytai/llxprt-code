{
  "name": "@vybestack/llxprt-code-policy",
  "version": "0.10.0",
  "description": "LLxprt Code Policy — policy engine and confirmation bus",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vybestack/llxprt-code.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./index.ts",
      "import": "./dist/index.js"
    },
    "./types.js": {
      "bun": "./src/types.ts",
      "import": "./dist/src/types.js"
    },
    "./policy-engine.js": {
      "bun": "./src/policy-engine.ts",
      "import": "./dist/src/policy-engine.js"
    },
    "./stable-stringify.js": {
      "bun": "./src/stable-stringify.ts",
      "import": "./dist/src/stable-stringify.js"
    },
    "./config.js": {
      "bun": "./src/config.ts",
      "import": "./dist/src/config.js"
    },
    "./toml-loader.js": {
      "bun": "./src/toml-loader.ts",
      "import": "./dist/src/toml-loader.js"
    },
    "./utils.js": {
      "bun": "./src/utils.ts",
      "import": "./dist/src/utils.js"
    },
    "./confirmation-bus/index.js": {
      "bun": "./src/confirmation-bus/index.ts",
      "import": "./dist/src/confirmation-bus/index.js"
    },
    "./confirmation-bus/types.js": {
      "bun": "./src/confirmation-bus/types.ts",
      "import": "./dist/src/confirmation-bus/types.js"
    },
    "./confirmation-bus/message-bus.js": {
      "bun": "./src/confirmation-bus/message-bus.ts",
      "import": "./dist/src/confirmation-bus/message-bus.js"
    }
  },
  "scripts": {
    "build": "bun ../../scripts/build_package.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "test": "bun test --path-ignore-patterns research",
    "test:vitest": "vitest run",
    "test:ci": "bun test --path-ignore-patterns research",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "index.ts",
    "src",
    "!**/*.test.ts",
    "!**/*.test.tsx",
    "!**/*.spec.ts",
    "!**/*.spec.tsx",
    "!**/__tests__/**",
    "!**/__snapshots__/**",
    "dist"
  ],
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.2.1",
    "fast-check": "^4.2.0",
    "typescript": "^5.3.3",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=24"
  }
}
