{
  "name": "@vybestack/llxprt-code-telemetry",
  "version": "0.10.0",
  "description": "LLxprt Code Telemetry — debug logging, OpenTelemetry instrumentation, and metrics",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vybestack/llxprt-code.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./index.ts",
      "import": "./dist/index.js"
    },
    "./debug/index.js": {
      "bun": "./src/debug/index.ts",
      "import": "./dist/src/debug/index.js"
    },
    "./debug/DebugLogger.js": {
      "bun": "./src/debug/DebugLogger.ts",
      "import": "./dist/src/debug/DebugLogger.js"
    },
    "./debug/ConfigurationManager.js": {
      "bun": "./src/debug/ConfigurationManager.ts",
      "import": "./dist/src/debug/ConfigurationManager.js"
    },
    "./debug/FileOutput.js": {
      "bun": "./src/debug/FileOutput.ts",
      "import": "./dist/src/debug/FileOutput.js"
    },
    "./debug/MockConfigurationManager.js": {
      "bun": "./src/debug/MockConfigurationManager.ts",
      "import": "./dist/src/debug/MockConfigurationManager.js"
    },
    "./debug/MockFileOutput.js": {
      "bun": "./src/debug/MockFileOutput.ts",
      "import": "./dist/src/debug/MockFileOutput.js"
    },
    "./utils/index.js": {
      "bun": "./src/utils/index.ts",
      "import": "./dist/src/utils/index.js"
    },
    "./utils/debugLogger.js": {
      "bun": "./src/utils/debugLogger.ts",
      "import": "./dist/src/utils/debugLogger.js"
    },
    "./utils/safeJsonStringify.js": {
      "bun": "./src/utils/safeJsonStringify.ts",
      "import": "./dist/src/utils/safeJsonStringify.js"
    },
    "./utils/session.js": {
      "bun": "./src/utils/session.ts",
      "import": "./dist/src/utils/session.js"
    },
    "./telemetry/loggers.js": {
      "bun": "./src/telemetry/loggers.ts",
      "import": "./dist/src/telemetry/loggers.js"
    },
    "./telemetry/types.js": {
      "bun": "./src/telemetry/types.ts",
      "import": "./dist/src/telemetry/types.js"
    },
    "./telemetry/index.js": {
      "bun": "./src/telemetry/index.ts",
      "import": "./dist/src/telemetry/index.js"
    },
    "./telemetry/sdk.js": {
      "bun": "./src/telemetry/sdk.ts",
      "import": "./dist/src/telemetry/sdk.js"
    },
    "./telemetry/constants.js": {
      "bun": "./src/telemetry/constants.ts",
      "import": "./dist/src/telemetry/constants.js"
    },
    "./telemetry/metrics.js": {
      "bun": "./src/telemetry/metrics.ts",
      "import": "./dist/src/telemetry/metrics.js"
    },
    "./telemetry/uiTelemetry.js": {
      "bun": "./src/telemetry/uiTelemetry.ts",
      "import": "./dist/src/telemetry/uiTelemetry.js"
    },
    "./telemetry/tool-call-decision.js": {
      "bun": "./src/telemetry/tool-call-decision.ts",
      "import": "./dist/src/telemetry/tool-call-decision.js"
    },
    "./telemetry/file-exporters.js": {
      "bun": "./src/telemetry/file-exporters.ts",
      "import": "./dist/src/telemetry/file-exporters.js"
    }
  },
  "scripts": {
    "build": "bun ../../scripts/build_package.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:ci": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "index.ts",
    "src",
    "!**/*.test.ts",
    "!**/*.test.tsx",
    "!**/*.spec.ts",
    "!**/*.spec.tsx",
    "!**/__tests__/**",
    "!**/__snapshots__/**",
    "dist"
  ],
  "dependencies": {
    "@google/genai": "1.30.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.219.0",
    "@opentelemetry/core": "^2.8.0",
    "@opentelemetry/exporter-logs-otlp-grpc": "^0.219.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.219.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/instrumentation-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-logs": "^0.219.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.29.0",
    "debug": "^4.3.4"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/node": "^24.2.1",
    "fast-check": "^4.2.0",
    "typescript": "^5.3.3",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=24"
  }
}
