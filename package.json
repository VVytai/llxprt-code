{
  "name": "@vybestack/llxprt-code",
  "version": "0.10.0",
  "engines": {
    "node": ">=24",
    "bun": ">=1.3.14"
  },
  "type": "module",
  "workspaces": [
    "packages/tools",
    "packages/storage",
    "packages/auth",
    "packages/settings",
    "packages/telemetry",
    "packages/ide-integration",
    "packages/policy",
    "packages/mcp",
    "packages/core",
    "packages/lsp",
    "packages/providers",
    "packages/agents",
    "packages/cli",
    "packages/a2a-server",
    "packages/test-utils",
    "packages/vscode-ide-companion"
  ],
  "trustedDependencies": [
    "@ast-grep/lang-c",
    "@ast-grep/lang-cpp",
    "@ast-grep/lang-csharp",
    "@ast-grep/lang-go",
    "@ast-grep/lang-java",
    "@ast-grep/lang-json",
    "@ast-grep/lang-kotlin",
    "@ast-grep/lang-php",
    "@ast-grep/lang-python",
    "@ast-grep/lang-ruby",
    "@ast-grep/lang-rust",
    "@ast-grep/lang-scala",
    "@ast-grep/lang-swift",
    "@lvce-editor/ripgrep",
    "bun",
